# Admin panel secret — required in production (Vercel env var).
# Local dev default: flappy-admin (when unset).
ADMIN_SECRET=your-secret-here

# Optional: enables global leaderboard and production character persistence.
flappybase_KV_REST_API_URL=your-upstash-rest-url
flappybase_KV_REST_API_TOKEN=your-upstash-rest-token
